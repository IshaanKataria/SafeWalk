DATABASE_URL=postgresql://safewalk:safewalk@localhost:5433/safewalk
GOOGLE_MAPS_API_KEY=
# USE_MOCK_DATA is informational only. When a Google Maps API key is set, the
# backend always calls the live Directions API. Mock sample routes are used
# only if the key is missing or the API call fails.
USE_MOCK_DATA=false
SCORING_ENGINE=mock
# Dataset: "london" = real Barnet data, "mock" = synthetic Clayton data
DATA_SOURCE=london
